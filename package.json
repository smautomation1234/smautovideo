{
  "name": "reelforge-omni",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names web,worker --prefix-colors cyan,magenta \"npm:dev:web\" \"npm:worker\"",
    "dev:web": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "worker": "tsx --env-file=.env scripts/run-worker.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "google-auth-library": "^10.3.0",
    "mediabunny": "^1.50.8",
    "next": "^15.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.20",
    "tsx": "^4.23.1",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
